CXX=clang++
FC=gfortran
AS=as

# Macros
CND_PLATFORM=CLang-Linux
CND_DLIB_EXT=so
CND_CONF=Release
CND_DISTDIR=dist
CND_BUILDDIR=build

# Include project Makefile
include xitools-Makefile.mk

# Object Directory
OBJECTDIR=${CND_BUILDDIR}/${CND_CONF}/${CND_PLATFORM}

# Object Files
OBJECTFILES= \
	${OBJECTDIR}/Params.o \
	${OBJECTDIR}/Parser.o \
	${OBJECTDIR}/RunInfo.o \
	${OBJECTDIR}/StoeSum.o \
	${OBJECTDIR}/Usage.o \
	${OBJECTDIR}/Utils.o \
	${OBJECTDIR}/io.o \
	${OBJECTDIR}/main.o


# C Compiler Flags
CFLAGS=

# CC Compiler Flags
